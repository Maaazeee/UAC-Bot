<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UAC Bot - Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: #0f0f1a; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
    .glow { box-shadow: 0 0 40px rgba(88,101,242,0.15); }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="bg-[#16213e] border border-[#252540] rounded-2xl p-8 text-center glow">
      <div class="text-5xl mb-4">🤖</div>
      <h1 class="text-2xl font-bold text-white mb-2">UAC Bot</h1>
      <p class="text-gray-400 mb-8">Tableau de bord de configuration</p>

      <% if (user) { %>
        <div class="flex items-center gap-3 justify-center mb-6">
          <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="w-10 h-10 rounded-full" alt="">
          <span class="text-white font-medium"><%= user.username %></span>
        </div>
        <div class="flex gap-3 justify-center">
          <a href="/dashboard" class="flex-1 bg-[#5865F2] hover:bg-[#4752c4] text-white font-semibold py-3 px-6 rounded-xl transition text-center">Dashboard</a>
          <a href="/logout" class="bg-gray-700 hover:bg-gray-600 text-gray-300 font-semibold py-3 px-6 rounded-xl transition">Déconnexion</a>
        </div>
      <% } else { %>
        <a href="/login" class="block bg-[#5865F2] hover:bg-[#4752c4] text-white font-semibold py-3 px-6 rounded-xl transition">
          Connexion avec Discord
        </a>
      <% } %>
    </div>
    <p class="text-center text-gray-600 text-xs mt-6">UAC Bot &mdash; Gestion complète de votre serveur Discord</p>
  </div>
</body>
</html>
