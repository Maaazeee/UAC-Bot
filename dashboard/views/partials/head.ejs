<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>UAC Bot</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<style>
  body { background: #0f0f1a; }
  .sidebar-link { transition: all 0.15s; }
  .sidebar-link:hover { background: rgba(88,101,242,0.15); color: #fff; }
  .sidebar-link.active { background: rgba(88,101,242,0.2); color: #5865F2; border-right: 3px solid #5865F2; }
  .card { background: #1a1a2e; border: 1px solid #252540; border-radius: 12px; }
  .card-header { border-bottom: 1px solid #252540; padding: 1rem 1.5rem; }
  .card-body { padding: 1.5rem; }
  input, select, textarea { background: #0f0f1a; border: 1px solid #252540; color: #e2e8f0; border-radius: 8px; padding: 0.625rem 1rem; width: 100%; }
  input:focus, select:focus, textarea:focus { outline: none; border-color: #5865F2; ring: 2px solid rgba(88,101,242,0.3); }
  .btn-primary { background: #5865F2; color: #fff; padding: 0.625rem 1.5rem; border-radius: 8px; font-weight: 600; transition: all 0.15s; }
  .btn-primary:hover { background: #4752c4; }
  .btn-danger { background: #ed4245; color: #fff; padding: 0.625rem 1.5rem; border-radius: 8px; font-weight: 600; transition: all 0.15s; }
  .btn-danger:hover { background: #c03537; }
  .btn-ghost { color: #94a3b8; padding: 0.5rem 1rem; border-radius: 8px; font-weight: 500; transition: all 0.15s; }
  .btn-ghost:hover { background: rgba(255,255,255,0.05); color: #fff; }
  .toast { animation: slideIn 0.3s ease; }
  @keyframes slideIn { from { transform: translateY(-10px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #0f0f1a; }
  ::-webkit-scrollbar-thumb { background: #252540; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #3a3a5c; }
</style>
