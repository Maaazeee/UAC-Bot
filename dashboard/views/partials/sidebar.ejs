<nav class="fixed left-0 top-0 bottom-0 w-60 bg-[#16213e] border-r border-[#252540] p-4 flex flex-col">
  <a href="/dashboard" class="flex items-center gap-3 mb-8 px-3">
    <span class="text-2xl">🤖</span>
    <span class="font-bold text-lg text-white">UAC Bot</span>
  </a>
  <div class="flex-1 space-y-1">
    <% var pages = [
      { icon: '📊', name: 'Vue d\'ensemble', url: `/dashboard/${guild.id}/stats` },
      { icon: '⚙️', name: 'Configuration', url: `/dashboard/${guild.id}` },
      { icon: '📈', name: 'Niveaux', url: `/dashboard/${guild.id}/levels` },
      { icon: '💰', name: 'Économie', url: `/dashboard/${guild.id}/economy` },
      { icon: '🛡️', name: 'Modération', url: `/dashboard/${guild.id}/moderation` },
      { icon: '🏰', name: 'Clans', url: `/dashboard/${guild.id}/clans` },
      { icon: '📋', name: 'Logs', url: `/dashboard/${guild.id}/logs` },
    ]; %>
    <% pages.forEach(function(p) { %>
      <a href="<%= p.url %>" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-gray-400 <%= currentPage === p.name ? 'active' : '' %>">
        <span><%= p.icon %></span>
        <span><%= p.name %></span>
      </a>
    <% }); %>
  </div>
  <div class="border-t border-[#252540] pt-4 mt-4">
    <a href="/dashboard" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-gray-400">
      <span>🏠</span>
      <span>Mes serveurs</span>
    </a>
    <a href="/logout" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-gray-400">
      <span>🚪</span>
      <span>Déconnexion</span>
    </a>
  </div>
</nav>
