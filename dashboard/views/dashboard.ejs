<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - UAC Bot</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #1a1a2e; color: #eee; min-height: 100vh; }
    nav { background: #16213e; padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #2a2a4a; }
    nav h2 { font-size: 1.2rem; }
    nav .user { display: flex; align-items: center; gap: 8px; }
    nav .avatar { width: 32px; height: 32px; border-radius: 50%; }
    nav a { color: #aaa; text-decoration: none; }
    nav a:hover { color: #fff; }
    .container { max-width: 800px; margin: 2rem auto; padding: 0 1rem; }
    h1 { margin-bottom: 1.5rem; }
    .guild-list { display: grid; gap: 12px; }
    .guild-card { background: #16213e; padding: 1rem 1.5rem; border-radius: 12px; display: flex; align-items: center; justify-content: space-between; }
    .guild-card .info { display: flex; align-items: center; gap: 12px; }
    .guild-card .icon { width: 40px; height: 40px; border-radius: 50%; background: #2a2a4a; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
    .guild-card .icon img { width: 40px; height: 40px; border-radius: 50%; }
    .guild-card .name { font-weight: 600; }
    .btn { padding: 8px 20px; background: #5865F2; color: white; text-decoration: none; border-radius: 6px; font-size: 0.9rem; }
    .btn:hover { background: #4752c4; }
    .back { display: inline-block; margin-bottom: 1rem; color: #aaa; text-decoration: none; }
    .back:hover { color: #fff; }
    .empty { text-align: center; padding: 3rem; color: #666; }
  </style>
</head>
<body>
  <nav>
    <h2>🤖 UAC Bot</h2>
    <div class="user">
      <img class="avatar" src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="">
      <span><%= user.username %></span>
      <a href="/logout">Déconnexion</a>
    </div>
  </nav>
  <div class="container">
    <h1>Mes serveurs</h1>
    <% if (guilds.length === 0) { %>
      <div class="empty">Aucun serveur administrable trouvé.</div>
    <% } else { %>
      <div class="guild-list">
        <% guilds.forEach(g => { %>
          <div class="guild-card">
            <div class="info">
              <div class="icon">
                <% if (g.icon) { %>
                  <img src="https://cdn.discordapp.com/icons/<%= g.id %>/<%= g.icon %>.png" alt="">
                <% } else { %>
                  🏠
                <% } %>
              </div>
              <span class="name"><%= g.name %></span>
            </div>
            <a href="/dashboard/<%= g.id %>" class="btn">Configurer</a>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</body>
</html>
